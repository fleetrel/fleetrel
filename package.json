{
  "name": "fleetrel",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": "24.x.x",
    "pnpm": "11.x.x"
  },
  "scripts": {
    "prepare": "husky",
    "postinstall": "sh ./tools/generate-types.sh",
    "build": "nx run-many -t build",
    "lint": "nx run-many -t lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "nx run-many -t lint build && prettier --check .",
    "check:affected": "nx affected -t lint build --base=HEAD~1 --head=HEAD && prettier --check .",
    "check:affected:ci:pr": "nx affected -t lint build --base=origin/main --head=HEAD --outputStyle=static && prettier --check .",
    "check:affected:ci:push": "nx affected -t lint build --base=origin/main~1 --head=origin/main --outputStyle=static && prettier --check .",
    "serve:api": "nx serve panel-api",
    "docker:dev:up": "docker compose -f docker-compose.dev.yml up -d",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.4.4",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "i18next": "^26.2.0",
    "nestjs-zod": "^5.4.0",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/eslint": "22.7.5",
    "@nx/eslint-plugin": "22.7.5",
    "@nx/js": "22.7.5",
    "@nx/nest": "22.7.5",
    "@nx/node": "22.7.5",
    "@nx/web": "22.7.5",
    "@nx/webpack": "22.7.5",
    "@nx/workspace": "22.7.5",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/node": "25.9.1",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "nx": "22.7.5",
    "prettier": "~3.8.3",
    "prisma": "^7.8.0",
    "tslib": "^2.3.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.40.0",
    "webpack-cli": "^7.0.2"
  }
}
